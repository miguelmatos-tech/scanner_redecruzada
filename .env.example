# --- Application Info ---
APP_TITLE="Rede Cruzada"
BASE_URL="http://localhost:7331"
PORT=7331
SELF_HOSTED_MODE=true

# --- Database ---
# Local: postgresql://postgres:postgres@localhost:5432/redecruzada
# Supabase: postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres
DATABASE_URL=""

# --- AI Providers ---
# Get yours at: https://aistudio.google.com/
GOOGLE_API_KEY=""
GOOGLE_MODEL_NAME="gemini-2.0-flash"

# https://platform.openai.com/
OPENAI_API_KEY=""
OPENAI_MODEL_NAME="gpt-4o-mini"

# https://console.mistral.ai/
MISTRAL_API_KEY=""
MISTRAL_MODEL_NAME="mistral-medium-latest"

# --- Authentication ---
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET="please-set-your-key-here"
DISABLE_SIGNUP=false

# --- Email (Resend) ---
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Rede Cruzada <redecruzada@localhost>"
RESEND_AUDIENCE_ID=""

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Cloud Storage (Supabase) ---
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_BUCKET_NAME="uploads"
